# Build stage
FROM node:22-alpine AS builder

ARG NUXT_PUBLIC_API_URL=https://war-backend.fly.dev/graphql
ARG NUXT_PUBLIC_WS_URL=wss://war-backend.fly.dev/graphql
ENV NUXT_PUBLIC_API_URL=${NUXT_PUBLIC_API_URL}
ENV NUXT_PUBLIC_WS_URL=${NUXT_PUBLIC_WS_URL}

WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/frontend/package.json ./apps/frontend/
COPY packages/types/package.json ./packages/types/
COPY packages/utils/package.json ./packages/utils/
RUN npm install
COPY . .
RUN npm run build --workspace=apps/frontend

# Runtime stage
FROM node:22-alpine
WORKDIR /app
COPY --from=builder /app/apps/frontend/.output ./.output
ENV NUXT_HOST=0.0.0.0
ENV NUXT_PORT=3000
EXPOSE 3000
CMD ["node", ".output/server/index.mjs"]
